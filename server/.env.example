PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-string
DEVCLAW_ENCRYPTION_KEY=separate-long-key-for-encrypting-stored-api-keys
NODE_ENV=development

Optional usage caps (0 = unlimited). Counts are per DevClaw user, UTC day for daily limit.
DEVCLAW_DAILY_ASSISTANT_REPLY_LIMIT=200
DEVCLAW_MAX_CHATS=50
DEVCLAW_MAX_MESSAGES_PER_SESSION=400

# Sessions console: max shown in token ratio (used / cap). Default 200000.
# DEVCLAW_SESSION_TOKEN_CAP_DISPLAY=200000

When the API key is a Google (AIza) key but the model field is still an OpenAI id, call this Gemini model (Generative Language API id, no google/ prefix).
DEVCLAW_GEMINI_DEFAULT_MODEL=gemini-2.0-flash

When the model API returns 429/5xx or "high demand" / overload, retry a few times with backoff (exponential, capped).
DEVCLAW_MODEL_RETRY_MAX=3
DEVCLAW_MODEL_RETRY_BASE_MS=1000

# Set to 1 to block unauthenticated "quick chat" at /guest (omit or leave unset to allow — default for local dev).
# DEVCLAW_DISABLE_GUEST=1

Optional guest (/guest) caps. 0 = unlimited. Daily count is per hashed client IP (UTC day).
DEVCLAW_GUEST_DAILY_ASSISTANT_REPLY_LIMIT=50
Max user+assistant messages in one in-browser quick chat thread.
DEVCLAW_GUEST_MAX_THREAD_MESSAGES=200
Custom instructions (session) max length; merged into the system prompt, not stored on the server.
DEVCLAW_GUEST_MAX_CUSTOM_INSTRUCTIONS=2000
Optional salt for hashing the client IP in guest rate limits (change in production if exposed).
DEVCLAW_GUEST_SALT=change-in-production

# Signed-in usage dashboard: optional USD per 1M tokens for rough cost display (see server/src/usageRecord.js defaults).
# DEVCLAW_USAGE_OPENAI_IN_PER_1M=2.5
# DEVCLAW_USAGE_OPENAI_OUT_PER_1M=10
# DEVCLAW_USAGE_ANTHROPIC_IN_PER_1M=3
# DEVCLAW_USAGE_ANTHROPIC_OUT_PER_1M=15
# DEVCLAW_USAGE_GOOGLE_IN_PER_1M=0.15
# DEVCLAW_USAGE_GOOGLE_OUT_PER_1M=0.6
